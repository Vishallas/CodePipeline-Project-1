# Copy to terraform.tfvars and fill in real values
# Do NOT commit terraform.tfvars

aws_region     = "ap-south-1"
aws_account_id = "123456789012"

# Create via: aws codestar-connections create-connection --provider-type GitHub
# Then complete OAuth in AWS Console → Developer Tools → Connections
github_connection_arn = "arn:aws:codestar-connections:ap-south-1:123456789012:connection/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

packaging_repo = "pg-platform/pg-packaging"
platform_repo  = "pg-platform/pg-platform"

artifacts_bucket_name = "pg-platform-cicd-artifacts"
apt_bucket_name       = "pg-platform-apt-repo"
yum_bucket_name       = "pg-platform-yum-repo"

ecr_repository_name = "pg-platform/pg-build"

# gpg --list-secret-keys --keyid-format LONG
# gpg --export-secret-keys --armor YOUR_KEY_ID | base64 -w0
gpg_key_id          = "ABCDEF1234567890"
gpg_private_key_b64 = ""   # set via TF_VAR_gpg_private_key_b64 env var

pulp_url      = ""
pulp_password = ""

cloudfront_distribution_id = ""

pg_versions = ["14", "15", "16", "17"]

build_env = "staging"
